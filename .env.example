# ============ BACKEND ============
PORT=3001

# Jira
JIRA_HOST=tu-empresa.atlassian.net
JIRA_EMAIL=tu@email.com
JIRA_API_TOKEN=tu_token_de_jira
JIRA_PROJECT_KEY=DA
JIRA_DESIGN_LABEL=design-pending
# Kanban: mismos nombres que en tu tablero (coma = alternativas). El agente usa UN issue por historia (3 fases internas).
# Tras cada entrega → Por hacer (revisión en dashboard). Tras aprobar nivel 1 o 2 → Hecho, luego Reabrir→Por hacer→En curso para el siguiente nivel.
# Necesitás una transición desde Hecho hacia "Por hacer" (p. ej. "Reabrir"). Si no existe, poné JIRA_MOVE_TO_TODO_AFTER_DELIVERY=false.
JIRA_WORKFLOW_STATUS_TODO=Por hacer,To Do,Backlog
JIRA_WORKFLOW_STATUS_IN_PROGRESS=En curso,In Progress
JIRA_WORKFLOW_STATUS_DONE=Hecho,Done
# JIRA_MOVE_TO_TODO_AFTER_DELIVERY=false

# Gemini (mismo ecosistema que Antigravity; si 429, probá otro modelo)
GEMINI_API_KEY=tu_api_key_de_google
GEMINI_MODEL=gemini-3-flash-preview
# GEMINI_MODEL=gemini-2.5-flash
# GEMINI_MODEL=gemini-2.5-flash-lite

# Turso (SQLite Cloud)
# Si no tenés Turso, el backend usará local.db por defecto
TURSO_DATABASE_URL=libsql://design-agent-tuuser.turso.io
TURSO_AUTH_TOKEN=tu_token_de_turso

# Frontend (para CORS y links de Jira)
FRONTEND_URL=http://localhost:5173

# ============ FRONTEND ============
VITE_API_URL=http://localhost:3001
VITE_JIRA_HOST=tu-empresa.atlassian.net
