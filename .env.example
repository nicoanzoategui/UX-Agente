# ============ BACKEND (Framework UX) ============
PORT=3001

# Google AI (Gemini)
GEMINI_API_KEY=tu_api_key_de_google
GEMINI_MODEL=gemini-2.5-flash
# GEMINI_MODEL=gemini-2.5-flash-lite
# Más capacidad para HTML largo / alta fidelidad (recomendado si Flash trunca o falla en diseños grandes):
# GEMINI_MODEL=gemini-2.5-pro
# Ojo: nombres viejos tipo gemini-1.5-pro suelen dar 404 en la API actual; mirá https://ai.google.dev/gemini-api/docs/models

# Brief de viewport para wireframe alta fidelidad (misma idea que "viewport" en MCP tipo AIDesigner). Valores: desktop | mobile
# HIFI_VIEWPORT=desktop

# Proveedor del último paso (wireframe alta fidelidad): gemini | aidesigner
# Por defecto: gemini (mismo patrón público que muchas herramientas MCP: HTML + Tailwind CDN; sin créditos de terceros).
# HIFI_PROVIDER=gemini
# Con aidesigner: el backend ejecuta `npx @aidesigner/agent-skills generate` (mismo motor que el MCP; requiere Node/npx en el servidor).
# AIDESIGNER_API_KEY=tu_api_key
# AIDESIGNER_MCP_ACCESS_TOKEN=
# AIDESIGNER_BASE_URL=https://api.aidesigner.ai
# AIDESIGNER_OUT_DIR=   (vacío = <raíz del repo>/.aidesigner)
# HIFI_AIDESIGNER_TIMEOUT_MS=180000

# Turso (SQLite en la nube). Sin Turso, el backend puede usar SQLite local según tu configuración.
TURSO_DATABASE_URL=libsql://tu-db.turso.io
TURSO_AUTH_TOKEN=tu_token_de_turso

# Origen del frontend (CORS; debe coincidir con la URL del navegador para cookies).
# Podés listar varios separados por coma. En desarrollo el backend también acepta el espejo 127.0.0.1 ↔ localhost (mismo puerto).
FRONTEND_URL=http://localhost:5173

# --- Autenticación (sesión JWT en cookie httpOnly `fx_session`) ---
# Secreto para firmar el JWT (en producción: mín. 16 caracteres; nunca commitear el real).
JWT_SECRET=cambiar-en-produccion-minimo-16-chars

# Client ID de Google OAuth (tipo "Web application") — mismo valor en backend y VITE_GOOGLE_CLIENT_ID.
GOOGLE_CLIENT_ID=

# Allowlist: lista de emails separados por comas (minúsculas). Si está vacía, se usa dominio o se permite cualquier cuenta.
# ALLOWED_EMAILS=ana@empresa.com,bob@empresa.com

# Restringir por dominio (ej. @empresa.com). Ignorado si ALLOWED_EMAILS tiene entradas.
# ALLOWED_EMAIL_DOMAIN=@empresa.com

# NODE_ENV=production exige JWT_SECRET, GOOGLE_CLIENT_ID y prohíbe AUTH_DISABLED.
# NODE_ENV=development

# Solo local: sin Google; sesión fija en el API. Nunca en producción.
# AUTH_DISABLED=1

# Opcional: nombre de cookie (default fx_session) y validez del token en días (1–30, default 7).
# SESSION_COOKIE_NAME=fx_session
# JWT_EXPIRES_DAYS=7

# Producción (Vercel + Railway, dominios distintos): por defecto el código usa SameSite=None + Secure.
# Solo si front y API comparten mismo sitio y querés Lax:
# SESSION_COOKIE_SAMESITE=lax
# SESSION_COOKIE_SECURE=0   (solo si probás prod sin HTTPS; no uses en internet real)
# Dominio compartido (ej. app.tudominio.com + api.tudominio.com):
# SESSION_COOKIE_DOMAIN=.tudominio.com

# Tras nginx / load balancer (req.ip real para rate limit). En Railway también se activa trust proxy si existe RAILWAY_ENVIRONMENT.
# TRUST_PROXY=1

# Rate limit global en /api (por IP y proceso). Opcional.
# RATE_LIMIT_WINDOW_MS=900000
# RATE_LIMIT_MAX=600

# ============ FRONTEND ============
VITE_API_URL=http://localhost:3001

# Mismo Client ID que GOOGLE_CLIENT_ID del backend (para el botón de Google).
VITE_GOOGLE_CLIENT_ID=

# Opcional: muestra "Entrar sin Google" si el backend tiene AUTH_DISABLED=1 (solo desarrollo).
# VITE_AUTH_DISABLED=1
